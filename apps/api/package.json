{
  "name": "@grammashop/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsc && node dist/db/migrate.js",
    "db:seed": "tsx src/db/seed.ts",
    "verify:s3": "tsx src/s3/verify.ts",
    "backup:db": "tsx src/db/backup.ts",
    "restore-check:db": "tsx src/db/restore-check.ts",
    "anonymize-seller:db": "tsx src/db/anonymize-seller.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@grammashop/shared": "workspace:*",
    "@sentry/node": "^10.66.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "grammy": "^1.45.1",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
