{
  "name": "@grammashop/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsc && node dist/db/migrate.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@grammashop/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
