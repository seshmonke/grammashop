# Копировать в .env и заполнить реальными значениями. Ничего из .env не
# коммитится (см. .gitignore).

# --- Database (Postgres + Drizzle) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grammashop

# --- Auth (Telegram initData → сессия), см. STACK.md#авторизация ---
TELEGRAM_BOT_TOKEN=
# Секрет для подписи короткоживущих сессионных JWT (не путать с токеном бота)
JWT_SECRET=

# --- S3-совместимое хранилище файлов, см. STACK.md#хранилище-файлов ---
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Sentry, см. STACK.md#логирование-и-мониторинг ---
SENTRY_DSN_API=
SENTRY_DSN_WEB=

# --- Мастер-ключ шифрования платёжных ключей продавцов (ЮKassa/СДЭК) ---
# Хранится отдельно от БД, не в том же compose — см. задачу в очереди
# TASKS.md «Схема хранения платёжных ключей продавцов»
PAYMENT_KEYS_MASTER_KEY=

# --- Окружение ---
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
