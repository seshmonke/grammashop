# Копировать в .env и заполнить реальными значениями. Ничего из .env не
# коммитится (см. .gitignore).

# --- Database (Postgres + Drizzle) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grammashop
# Тестовая БД (см. docker/postgres-init/001-create-test-db.sql) — на неё
# переключаются интеграционные тесты apps/api (см. STACK.md#тестирование)
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/grammashop_test

# --- Auth (Telegram initData → сессия), см. STACK.md#авторизация ---
TELEGRAM_BOT_TOKEN=
# Секрет для подписи короткоживущих сессионных JWT (не путать с токеном бота)
JWT_SECRET=
# Telegram ID платформенных админов через запятую (числовые id, не username —
# см. STACK.md#авторизация: админы — env-список, не таблица)
ADMIN_TELEGRAM_IDS=
# Dev-режим авторизации: /auth принимает mock-initData без проверки HMAC —
# для отладки в браузере вне Telegram (см. STACK.md#авторизация, «Dev-режим»).
# Только "true" включает; при NODE_ENV=production приложение падает на старте.
# НЕ выставлять на бою.
AUTH_DEV_MODE=

# --- Dev seed (временный мост, пока нет регистрации и админки продавца) ---
# Читается seed-скриптом продавца-разработчика (apps/api ... db/seed.ts).
# telegram_id — ЧИСЛОВОЙ id (не username!), берётся у @userinfobot; нужен
# для входа в админку продавца позже, для витрины сгодится любое значение.
DEV_SELLER_TELEGRAM_ID=
# username без @ — идёт в telegram_username продавца (диплинк-связь).
DEV_SELLER_TELEGRAM_USERNAME=

# --- S3-совместимое хранилище файлов, см. STACK.md#хранилище-файлов ---
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Пароль-фраза симметричного GPG-шифрования дампов бэкапа (см.
# STACK.md#бэкапы) — отдельно от S3-ключей выше: узкая утечка
# S3-доступа не даёт прочитать содержимое бэкапов.
BACKUP_GPG_PASSPHRASE=

# --- Sentry, см. STACK.md#логирование-и-мониторинг ---
SENTRY_DSN_API=
# VITE_-префикс обязателен — Vite подставляет значение в бандл на этапе
# сборки (см. apps/web/Dockerfile), просто SENTRY_DSN_WEB браузер не увидит.
VITE_SENTRY_DSN_WEB=

# --- Биллинг подписки (ЮKassa), см. CONCEPT.md#оплата-подписки-продавцом ---
# Тестовый магазин (sandbox): ShopID + секретный ключ из ЛК ЮKassa. Тот
# же хост api.yookassa.ru/v3, что и бой — отличаются только эти ключи.
# Рекуррент в тестовом магазине включён по умолчанию.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Переопределение хоста API — только для тестов/мокинга, в проде не задавать.
YOOKASSA_API_URL=
# Сумма списания в копейках (Free-верификация = 100 = 1 ₽; цена Premium
# ещё считается). Пусто → 100.
SUBSCRIPTION_AMOUNT_KOPECKS=
# Возвратный URL после подтверждения оплаты продавцом (диплинк в ТМА).
SUBSCRIPTION_RETURN_URL=
# На бою — "true": фильтровать вебхук по IP-диапазонам ЮKassa
# (defense-in-depth; настоящая гарантия — перечитка платежа). В sandbox/
# dev/тестах не включать: адреса другие.
YOOKASSA_VERIFY_WEBHOOK_IP=
# Лимит запросов на вебхук-роут /billing/webhook в минуту (пусто → 60).
BILLING_WEBHOOK_RATE_LIMIT_MAX=

# --- Окружение ---
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173

# --- Frontend (apps/web), см. STACK.md#http-клиент ---
# Браузер обращается к apps/api напрямую по опубликованному порту —
# значение по умолчанию в коде (lib/api-client.ts) совпадает с этим.
VITE_API_URL=http://localhost:3000
# Dev-отладка витрины в браузере вне Telegram (см. shop/seller-id.ts,
# auth/init-data.ts). Telegram ID mock-пользователя и seller_id, чью витрину
# показывать без start_param. Только dev, в прод-бандл не идут.
VITE_DEV_TELEGRAM_ID=
VITE_DEV_SELLER_ID=
